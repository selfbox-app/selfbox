# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/selfbox

# ── Authentication (BetterAuth) ──────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-here
# In dev, portless sets PORTLESS_URL automatically (https://selfbox.localhost).
# Set BETTER_AUTH_URL explicitly for production.
# BETTER_AUTH_URL=https://your-production-domain.com

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Blob Storage ─────────────────────────────────────────────────────────────
# Provider: local | s3 | r2 | vercel | railway
BLOB_STORAGE_PROVIDER=local

# Local storage directory (when provider=local)
LOCAL_BLOB_DIR=./local-blobs

# AWS S3 (when provider=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=selfbox

# Cloudflare R2 (when provider=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=selfbox
# R2_PUBLIC_URL=

# Vercel Blob (when provider=vercel)
# BLOB_READ_WRITE_TOKEN=

# Railway Storage Buckets (when provider=railway)
# Auto-detected when running on Railway (RAILWAY_ENVIRONMENT_NAME is set).
# Uses Railway's injected vars: BUCKET_ENDPOINT, BUCKET_ACCESS_KEY_ID,
# BUCKET_SECRET_ACCESS_KEY, BUCKET_NAME — or the bucket's own vars:
# ENDPOINT, ACCESS_KEY_ID, SECRET_ACCESS_KEY, BUCKET.
# No manual config needed when deployed on Railway with a connected bucket.

# ── App ──────────────────────────────────────────────────────────────────────
# In dev, portless provides PORTLESS_URL (https://selfbox.localhost) automatically.
# Set NEXT_PUBLIC_APP_URL explicitly for production.
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com
NODE_ENV=development

# ── Email (Resend) ──────────────────────────────────────────────────────────
# RESEND_API_KEY=

# ── Plugin Secret Encryption ─────────────────────────────────────────────────
# Required in production. Must be stable — rotating this breaks stored plugin secrets.
# PLUGIN_ENCRYPTION_SECRET=your-stable-secret-here

# ── Storage Limits ───────────────────────────────────────────────────────────
# Max file size in bytes (default: 100MB)
# MAX_FILE_SIZE=104857600
# Max storage per user in bytes (default: 5GB)
# MAX_STORAGE_PER_USER=5368709120

# ── AI Provider ──────────────────────────────────────────────────────────
# Configure at least one AI provider. Gateway/router options handle all
# providers with a single key. Direct keys let you connect to each provider.
#
# Option 1: Vercel AI Gateway (routes all providers)
# AI_GATEWAY_API_KEY=
#
# Option 2: OpenRouter (routes all providers, recommended for self-hosted)
# OPENROUTER_API_KEY=
#
# Option 3: Direct provider API keys (set one or more)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# MINIMAX_API_KEY=
# GLM_API_KEY=
# KIMI_API_KEY=
#
# Default model (provider/model format)
# AI_GATEWAY_MODEL=openai/gpt-4o

# ── QMD Search Service ──────────────────────────────────────────────────────
# URL of the QMD search service (run via Docker Compose or standalone)
# QMD_SERVICE_URL=http://localhost:9600
# Shared secret for authenticating requests between Selfbox and QMD service
# QMD_API_SECRET=your-shared-secret-here

# ── Desktop sync app distribution ────────────────────────────────────────────
# GitHub repo (owner/name) where the desktop-sync release workflow publishes
# .dmg / .msi / .exe artifacts. Read by /download (lists download buttons)
# and /api/desktop-updates/latest (the auto-updater manifest endpoint).
# SELFBOX_DESKTOP_RELEASES_REPO=selfbox/selfbox

