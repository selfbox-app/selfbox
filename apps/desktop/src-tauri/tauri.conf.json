{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/tauri-plugin-config-schema/main/schema.json",
  "productName": "Selfbox Desktop Sync",
  "version": "0.1.0",
  "identifier": "com.selfbox.desktop-sync",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Selfbox",
        "width": 400,
        "height": 600,
        "resizable": false,
        "decorations": true,
        "center": true,
        "titleBarStyle": "Visible",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https: http://localhost:1420 ws://localhost:1420; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Selfbox",
    "copyright": "Copyright \u00a9 2026 Selfbox",
    "category": "public.app-category.productivity",
    "shortDescription": "Sync a folder on your Mac or PC with a Selfbox workspace.",
    "longDescription": "Selfbox Desktop Sync keeps a folder on your computer in two-way sync with a Selfbox workspace. Drop files in, change them, organize them \u2014 everything propagates to the web in seconds, and changes from other devices flow back to your machine continuously.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://selfbox.app/api/desktop-updates/latest?platform={{target}}-{{arch}}&current_version={{current_version}}"
      ],
      "pubkey": "REPLACE_ME_BEFORE_FIRST_SIGNED_RELEASE"
    }
  }
}
